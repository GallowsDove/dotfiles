  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "{{dank16.color8.default.hex}}",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string punctuation.section.embedded"],
      "settings": {
        "foreground": "{{dank16.color2.default.hex}}"
      }
    },
    {
      "name": "Numbers And Constants",
      "scope": ["constant", "constant.numeric", "constant.language"],
      "settings": {
        "foreground": "{{dank16.color5.default.hex}}"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage", "storage.type"],
      "settings": {
        "foreground": "{{dank16.color1.default.hex}}"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "{{dank16.color4.default.hex}}"
      }
    },
    {
      "name": "Types",
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": {
        "foreground": "{{dank16.color6.default.hex}}"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "identifier"],
      "settings": {
        "foreground": "{{colors.on_background.default.hex}}"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "{{dank16.color7.default.hex}}"
      }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.property-name", "entity.name.tag"],
      "settings": {
        "foreground": "{{dank16.color3.default.hex}}"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "{{colors.on_error.default.hex}}",
        "background": "{{colors.error.default.hex}}"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "{{dank16.color6.default.hex}}",
    "class": "{{dank16.color6.default.hex}}",
    "enum": "{{dank16.color6.default.hex}}",
    "interface": "{{dank16.color6.default.hex}}",
    "type": "{{dank16.color6.default.hex}}",
    "typeParameter": "{{dank16.color6.default.hex}}",
    "function": "{{dank16.color4.default.hex}}",
    "method": "{{dank16.color4.default.hex}}",
    "macro": "{{dank16.color3.default.hex}}",
    "variable": "{{colors.on_background.default.hex}}",
    "parameter": "{{dank16.color7.default.hex}}",
    "property": "{{dank16.color3.default.hex}}",
    "enumMember": "{{dank16.color5.default.hex}}",
    "keyword": "{{dank16.color1.default.hex}}",
    "string": "{{dank16.color2.default.hex}}",
    "number": "{{dank16.color5.default.hex}}",
    "comment": {
      "foreground": "{{dank16.color8.default.hex}}",
      "italic": true
    }
  }
}